# Email Alert Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_FROM=your-email@gmail.com
ALERT_TO=your-email@gmail.com

# WhatsApp Alerts (Callmebot - Free)
# Setup guide: https://www.callmebot.com/blog/free-api-whatsapp-messages/
WHATSAPP_PHONE=+923001234567
WHATSAPP_APIKEY=

# Check interval in minutes (default: 1)
CHECK_INTERVAL=1

# SSL warning threshold in days (default: 14)
SSL_WARN_DAYS=14
